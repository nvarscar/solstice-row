# Domain configuration
# Used by nginx/certbot scripts (VPS) and Next.js metadata (all deployments)
DOMAIN=solsticerow.ca
EMAIL=admin@solsticerow.ca
NEXT_PUBLIC_SITE_URL=https://solsticerow.ca

# Cloudflare Turnstile (get free keys at https://cloudflare.com/turnstile)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Data directory for SQLite (default /data in Docker, content/ locally)
DATA_DIR=/data

# Let's Encrypt directory for nginx TLS (VPS deployments only)
LETSENCRYPT_DIR=/etc/letsencrypt
