# ── Runtime env vars (docker-compose / .env on VPS) ──────────────────────────

# Domain — used by nginx/certbot scripts and Next.js metadata
DOMAIN=solsticerow.ca
EMAIL=admin@solsticerow.ca
NEXT_PUBLIC_SITE_URL=https://solsticerow.ca

# Data directory for SQLite (default /data in Docker, content/ locally)
DATA_DIR=/data

# Let's Encrypt directory for nginx TLS (VPS deployments only)
LETSENCRYPT_DIR=/etc/letsencrypt

# ── Cloudflare Turnstile (https://cloudflare.com/turnstile) ──────────────────
#
# TURNSTILE_SITE_KEY is the Cloudflare Turnstile site key (public, but kept server-side).
# The register page reads it server-side and passes it as a prop — no build arg needed.
# On VPS / docker-compose: set it here.
# On Fly.io: fly secrets set TURNSTILE_SITE_KEY=...
TURNSTILE_SITE_KEY=

# TURNSTILE_SECRET_KEY is SECRET — never commit a real value.
# On VPS / docker-compose: set it here (read server-side only).
# On Fly.io: fly secrets set TURNSTILE_SECRET_KEY=<your_secret_key>
TURNSTILE_SECRET_KEY=
